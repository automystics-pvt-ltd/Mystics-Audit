# ══════════════════════════════════════════════════════
#  Mystics Audit — Production Environment Variables
#  Copy to .env.production and fill in real values.
#  NEVER commit .env.production to git.
# ══════════════════════════════════════════════════════

# ── API server port (internal, Nginx proxies to this) ─
API_PORT=3500

# ── Frontend base path (use / for root domain) ────────
BASE_PATH=/

# ── PostgreSQL connection ─────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Create DB on server (see below):
#   sudo -u postgres psql
#   CREATE USER mystics_user WITH PASSWORD 'your_password';
#   CREATE DATABASE mystics_audit OWNER mystics_user;
#   GRANT ALL PRIVILEGES ON DATABASE mystics_audit TO mystics_user;
DATABASE_URL=postgresql://mystics_user:your_password@localhost:5432/mystics_audit

# ── Session signing secret (generate a long random string)
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── SMTP (for email notifications — optional) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@automystics.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=Mystics Audit <noreply@automystics.com>

# ── Node environment ──────────────────────────────────
NODE_ENV=production
